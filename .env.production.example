POSTGRES_DB=inhouse_chat
POSTGRES_USER=chat_admin
POSTGRES_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=chat-attachments

JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret

APP_ORIGIN=https://chat.example.com

# Frontend build-time config
# Keep /api if nginx proxies REST to backend on the same domain.
NEXT_PUBLIC_API_BASE=/api

# Leave empty to use the same host for Socket.IO namespace /chat.
NEXT_PUBLIC_SOCKET_BASE=
