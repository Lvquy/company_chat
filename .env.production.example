MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin101091
MINIO_BUCKET=chat-attachments

JWT_ACCESS_SECRET=replace-with-long-random-secret-lvquy
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-lvquy

