# Nginx host-level config sample
# Copy file này sang server, ví dụ:
#   /etc/nginx/conf.d/chat.lvquy.id.vn.conf
#
# Yêu cầu:
# - Docker stack đang chạy app nội bộ ở 127.0.0.1:8080
# - Domain chat.lvquy.id.vn đã trỏ về IP server
# - Sau khi copy file, chạy:
#     nginx -t && systemctl reload nginx
# - Sau đó cấp SSL:
#     certbot --nginx -d chat.lvquy.id.vn

upstream company_chat_app {
  server 127.0.0.1:8080;
  keepalive 32;
}

server {
  listen 80;
  listen [::]:80;
  server_name chat.lvquy.id.vn;

  client_max_body_size 100m;

  location / {
    proxy_pass http://company_chat_app;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }
}

# Sau khi certbot cấp SSL xong, có thể dùng block HTTPS thủ công như dưới đây
